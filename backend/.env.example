# Supabase — found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
# Use the service_role key (not anon) — this bypasses RLS and must be kept secret
SUPABASE_SERVICE_KEY=<your-service-role-key>

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-<your-key-here>

# Claude model to use (optional — defaults shown)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Adjudication confidence thresholds (optional — defaults shown)
CONFIDENCE_APPROVE=0.80
CONFIDENCE_REJECT=0.50

# App settings (optional — defaults shown)
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
